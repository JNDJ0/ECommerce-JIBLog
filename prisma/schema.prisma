generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  password  String
  address   Int
  role      String
  ownerId   Int?
  orders    Order[]
  owner     Owner?
  deliverer Deliverer?
}

model Owner {
  id       Int       @id @default(autoincrement())
  userId   Int       @unique
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
}

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  description String
  location    Int
  price       Float
  quantity    Int     @default(0)
  ownerId     Int
  orders      Order[]
  owner       Owner   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model Order {
  id          Int        @id @default(autoincrement())
  code        String     @unique @default(uuid())
  payment     String
  delivery    Float
  status      String     @default("PENDENTE")
  userId      Int
  productId   Int
  delivererId Int?
  product     Product    @relation(fields: [productId], references: [id])
  user        User       @relation(fields: [userId], references: [id])
  deliverer   Deliverer? @relation(fields: [delivererId], references: [id])
  review      Review?
}

model Deliverer {
  id     Int     @id @default(autoincrement())
  userId Int     @unique
  region String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
}

model Review {
  id        Int     @id @default(autoincrement())
  orderId   Int     @unique
  rating    Int
  comment   String?
  order     Order   @relation(fields: [orderId], references: [id])
}
